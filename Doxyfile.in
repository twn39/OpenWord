PROJECT_NAME           = "OpenWord"
PROJECT_NUMBER         = "1.0.0"
PROJECT_BRIEF          = "Modern C++17 library for parsing, manipulating, and saving DOCX files."

OUTPUT_DIRECTORY       = "@CMAKE_CURRENT_BINARY_DIR@/docs_doxygen"
INPUT                  = "@CMAKE_CURRENT_SOURCE_DIR@/include/openword" "@CMAKE_CURRENT_SOURCE_DIR@/README.md"
USE_MDFILE_AS_MAINPAGE = "@CMAKE_CURRENT_SOURCE_DIR@/README.md"

RECURSIVE              = YES
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO
GENERATE_XML           = NO

HTML_COLORSTYLE_HUE    = 220
HTML_COLORSTYLE_SAT    = 100
HTML_COLORSTYLE_GAMMA  = 80
HTML_TIMESTAMP         = YES
HTML_DYNAMIC_MENUS     = YES
HTML_INDEX_NUM_ENTRIES = 100

WARN_IF_UNDOCUMENTED   = NO
